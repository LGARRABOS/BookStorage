# This unit is triggered by bookstorage-update.path when an update request is queued.
[Unit]
Description=BookStorage - Apply queued update (root worker)
After=network.target

[Service]
Type=oneshot
User=root
Group=root
WorkingDirectory=/opt/bookstorage
ExecStart=/usr/local/bin/bookstorage-update-worker
StandardOutput=journal
StandardError=journal
SyslogIdentifier=bookstorage-update

