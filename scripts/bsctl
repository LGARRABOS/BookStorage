#!/bin/bash
# ============================================================================
# bsctl - BookStorage Control
# ============================================================================
# CLI to manage BookStorage
# Usage: bsctl <command>
# ============================================================================

set -e

APP_NAME="bookstorage"
APP_VERSION="5.1.4"
APP_USER="nobody"
APP_GROUP="nobody"
INSTALL_DIR="/opt/bookstorage"
BIN_DIR="/usr/local/bin"

# Colors (ANSI C quoting for real ESC bytes)
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[0;33m'
BLUE=$'\033[0;34m'
BOLD=$'\033[1m'
NC=$'\033[0m'

# Load library (repo: scripts/bsctl.lib.sh, installed: /usr/local/bin/bsctl.lib.sh)
_bsctl_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "${_bsctl_dir}/bsctl.lib.sh" ]]; then
    # shellcheck source=/dev/null
    source "${_bsctl_dir}/bsctl.lib.sh"
elif [[ -f "${BIN_DIR}/bsctl.lib.sh" ]]; then
    # shellcheck source=/dev/null
    source "${BIN_DIR}/bsctl.lib.sh"
else
    printf "✗ Missing bsctl library: bsctl.lib.sh\n"
    printf "  Expected at: %s/bsctl.lib.sh or %s/bsctl.lib.sh\n" "${_bsctl_dir}" "${BIN_DIR}"
    exit 1
fi

# ============================================================================
# Main
# ============================================================================

case "${1:-help}" in
    help|-h|--help)
        cmd_help
        ;;
    version|-v|--version)
        cmd_version
        ;;
    build)
        cmd_build
        ;;
    build-prod)
        cmd_build_prod
        ;;
    run)
        cmd_run
        ;;
    clean)
        cmd_clean
        ;;
    install)
        cmd_install
        ;;
    uninstall)
        cmd_uninstall
        ;;
    update)
        cmd_update "${2:-}"
        ;;
    fix-perms)
        cmd_fix_perms
        ;;
    start)
        cmd_start
        ;;
    stop)
        cmd_stop
        ;;
    restart)
        cmd_restart
        ;;
    status)
        cmd_status
        ;;
    logs)
        cmd_logs
        ;;
    *)
        printf "${YELLOW}Unknown command: ${1}${NC}\n\n"
        cmd_help
        exit 1
        ;;
esac
