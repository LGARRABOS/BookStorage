#!/bin/bash
# ============================================================================
# bsctl - BookStorage Control
# ============================================================================
# CLI to manage BookStorage
# Usage: bsctl <command>
# ============================================================================

set -e

APP_NAME="bookstorage"
APP_VERSION="5.4.1"
APP_USER="nobody"
APP_GROUP="nobody"
INSTALL_DIR="/opt/bookstorage"
BIN_DIR="/usr/local/bin"

# Colors (ANSI C quoting for real ESC bytes)
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[0;33m'
BLUE=$'\033[0;34m'
BOLD=$'\033[1m'
NC=$'\033[0m'

# Load library (repo: scripts/bsctl.lib.sh, installed: /usr/local/bin/bsctl.lib.sh)
_bsctl_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

_bsctl_lib_candidates=(
    "${_bsctl_dir}/bsctl.lib.sh"
    "${BIN_DIR}/bsctl.lib.sh"
    "$(pwd)/scripts/bsctl.lib.sh"
    "/opt/bookstorage/scripts/bsctl.lib.sh"
)

_bsctl_lib_found=""
for _p in "${_bsctl_lib_candidates[@]}"; do
    if [[ -f "${_p}" ]]; then
        _bsctl_lib_found="${_p}"
        break
    fi
done

if [[ -n "${_bsctl_lib_found}" ]]; then
    # shellcheck source=/dev/null
    source "${_bsctl_lib_found}"
else
    printf "✗ Missing bsctl library: bsctl.lib.sh\n"
    printf "  Looked for:\n"
    printf "    - %s\n" "${_bsctl_dir}/bsctl.lib.sh"
    printf "    - %s\n" "${BIN_DIR}/bsctl.lib.sh"
    printf "    - %s\n" "$(pwd)/scripts/bsctl.lib.sh"
    printf "    - %s\n" "/opt/bookstorage/scripts/bsctl.lib.sh"
    exit 1
fi

# ============================================================================
# Main
# ============================================================================

case "${1:-help}" in
    help|-h|--help)
        cmd_help
        ;;
    version|-v|--version)
        cmd_version
        ;;
    build)
        cmd_build
        ;;
    build-prod)
        cmd_build_prod
        ;;
    run)
        cmd_run
        ;;
    clean)
        cmd_clean
        ;;
    install)
        cmd_install
        ;;
    uninstall)
        cmd_uninstall
        ;;
    update)
        cmd_update "${2:-}"
        ;;
    fix-perms)
        cmd_fix_perms
        ;;
    start)
        cmd_start
        ;;
    stop)
        cmd_stop
        ;;
    restart)
        cmd_restart
        ;;
    status)
        cmd_status
        ;;
    logs)
        cmd_logs
        ;;
    *)
        printf "${YELLOW}Unknown command: ${1}${NC}\n\n"
        cmd_help
        exit 1
        ;;
esac
