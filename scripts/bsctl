#!/bin/bash
# ============================================================================
# bsctl - BookStorage Control
# ============================================================================
# CLI to manage BookStorage
# Usage: bsctl <command>
# ============================================================================

set -e

APP_NAME="bookstorage"
APP_VERSION="2.0.0"
APP_USER="nobody"
APP_GROUP="nobody"
INSTALL_DIR="/opt/bookstorage"
BIN_DIR="/usr/local/bin"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# ============================================================================
# Utility functions
# ============================================================================

print_header() {
    printf "\n"
    printf "${BOLD}╔════════════════════════════════════════╗${NC}\n"
    printf "${BOLD}║  📚 BookStorage Control v${APP_VERSION}        ║${NC}\n"
    printf "${BOLD}╚════════════════════════════════════════╝${NC}\n"
    printf "\n"
}

print_success() {
    printf "${GREEN}✓ $1${NC}\n"
}

print_error() {
    printf "${RED}✗ $1${NC}\n"
}

print_info() {
    printf "${BLUE}▶ $1${NC}\n"
}

print_step() {
    printf "${BLUE}[$1]${NC} $2\n"
}

# Validates a git branch name (alphanumeric, . _ / - only; no ..)
validate_git_branch_name() {
    local b="$1"
    if [[ -z "$b" ]]; then
        return 1
    fi
    if [[ "$b" == -* ]]; then
        return 1
    fi
    if [[ "$b" == *..* ]]; then
        return 1
    fi
    if [[ ! "$b" =~ ^[a-zA-Z0-9._/-]+$ ]]; then
        return 1
    fi
    return 0
}

# Trim spaces; add leading v if version looks like 1.2.3
normalize_tag() {
    local t="$1"
    t="${t#"${t%%[![:space:]]*}"}"
    t="${t%"${t##*[![:space:]]}"}"
    if [[ -z "$t" ]]; then
        return 1
    fi
    if [[ "$t" =~ ^[0-9]+\.[0-9]+\.[0-9]+ ]]; then
        t="v${t}"
    fi
    printf '%s' "$t"
}

# Abort if local changes would block checkout
require_clean_worktree() {
    if [[ -n "$(git status --porcelain 2>/dev/null)" ]]; then
        print_error "Working tree is not clean (uncommitted changes or untracked files)."
        printf "Commit, stash, or clean the repo in ${INSTALL_DIR:-.} before running update.\n"
        exit 1
    fi
}

# Newest-first: up to 3 tags matching vMAJOR.0.0
list_major_release_tags() {
    git tag -l 'v*' 2>/dev/null | grep -E '^v[0-9]+\.0\.0$' | sort -V | tail -n 3 | tac
}

# Interactive choice: returns tag name on stdout
prompt_release_choice() {
    if [[ ! -t 0 ]]; then
        print_error "Interactive release choice requires a TTY."
        printf "Set ${BOLD}BSCTL_UPDATE_TAG=vX.Y.Z${NC} (e.g. v3.1.1) or run: ${BOLD}bsctl update main${NC}\n"
        exit 1
    fi

    print_info "Fetching origin (branches + tags)..."
    git fetch origin
    git fetch origin --tags 2>/dev/null || git fetch --tags origin 2>/dev/null || true
    printf "\n"

    local majors
    majors=$(list_major_release_tags)
    local -a MAJOR_TAGS=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && MAJOR_TAGS+=("$line")
    done <<< "$majors"

    printf "\n${BOLD}Release to deploy${NC} (major tags vX.0.0, newest first):\n"
    local i
    for ((i = 0; i < ${#MAJOR_TAGS[@]}; i++)); do
        printf "  ${BOLD}%d)${NC} %s\n" "$((i + 1))" "${MAJOR_TAGS[$i]}"
    done
    if [[ ${#MAJOR_TAGS[@]} -eq 0 ]]; then
        printf "  ${YELLOW}(no vX.0.0 tags found — use ${BOLD}a${YELLOW} to enter a tag, or ${BOLD}bsctl update main${YELLOW})${NC}\n"
    fi
    printf "  ${BOLD}a)${NC} autre — enter a tag manually (e.g. v3.1.1)\n"
    printf "\n"

    local choice tag prompt_line
    if [[ ${#MAJOR_TAGS[@]} -gt 0 ]]; then
        prompt_line="Choice [1-${#MAJOR_TAGS[@]}|a] (empty = cancel): "
    else
        prompt_line="Choice [a] only (empty = cancel): "
    fi

    while true; do
        read -r -p "$prompt_line" choice || true
        choice=$(printf '%s' "$choice" | tr '[:upper:]' '[:lower:]')
        if [[ -z "$choice" ]]; then
            print_error "Cancelled."
            exit 1
        fi
        if [[ "$choice" == "a" || "$choice" == "autre" ]]; then
            read -r -p "Tag (e.g. v3.1.1): " tag || true
            if ! tag=$(normalize_tag "$tag"); then
                print_error "Empty tag."
                continue
            fi
            printf '%s' "$tag"
            return 0
        fi
        if [[ "$choice" =~ ^[0-9]+$ ]]; then
            local idx=$((choice - 1))
            if [[ $idx -ge 0 && $idx -lt ${#MAJOR_TAGS[@]} ]]; then
                printf '%s' "${MAJOR_TAGS[$idx]}"
                return 0
            fi
        fi
        if [[ ${#MAJOR_TAGS[@]} -eq 0 ]]; then
            print_error "No major vX.0.0 tags. Use a) to enter a tag, or: bsctl update main"
        else
            print_error "Invalid choice. Use 1–${#MAJOR_TAGS[@]}, or a."
        fi
    done
}

# Shared tail: build, install, restart (steps 4–8)
cmd_update_finish() {
    print_step "4/8" "Compiling..."
    cmd_build_prod
    printf "\n"

    print_step "5/8" "Installing binary..."
    cp ${APP_NAME} ${BIN_DIR}/
    print_success "Binary copied"
    printf "\n"

    print_step "6/8" "Updating bsctl script..."
    cp scripts/bsctl ${BIN_DIR}/
    chmod +x ${BIN_DIR}/bsctl
    print_success "bsctl updated"
    printf "\n"

    print_step "7/8" "Fixing permissions..."
    cmd_fix_perms
    printf "\n"

    print_step "8/8" "Restarting service..."
    if ! systemctl restart ${APP_NAME}; then
        printf "\n"
        print_error "Échec de la commande systemctl restart."
        printf "${YELLOW}Dernières lignes du journal :${NC}\n"
        journalctl -u ${APP_NAME} -n 20 --no-pager 2>/dev/null || true
        printf "\n${BLUE}Plus de détails :${NC} sudo journalctl -u ${APP_NAME} -xe\n"
        printf "${BLUE}Statut du service :${NC} sudo systemctl status ${APP_NAME}\n"
        exit 1
    fi

    sleep 0.5
    printf "\n"

    if systemctl is-active --quiet ${APP_NAME}; then
        print_success "Service redémarré correctement (actif)."
        printf "\n"
        printf "${GREEN}╔════════════════════════════════════════╗${NC}\n"
        printf "${GREEN}║         MISE À JOUR TERMINÉE ✓          ║${NC}\n"
        printf "${GREEN}╚════════════════════════════════════════╝${NC}\n"
        printf "\n"
    else
        print_error "Le service n'est pas actif après le redémarrage."
        printf "${YELLOW}Dernières lignes du journal :${NC}\n"
        journalctl -u ${APP_NAME} -n 25 --no-pager 2>/dev/null || true
        printf "\n${BLUE}Pour diagnostiquer :${NC}\n"
        printf "  sudo journalctl -u ${APP_NAME} -xe\n"
        printf "  sudo systemctl status ${APP_NAME}\n"
        exit 1
    fi
}

cmd_update_at_tag() {
    local tag="$1"
    if [[ -z "$tag" ]]; then
        print_error "No tag selected."
        exit 1
    fi

    print_header
    print_info "Target release: ${BOLD}${tag}${NC}"
    printf "\n"

    print_step "1/8" "Fetching from origin (branches + tags)..."
    git fetch origin
    git fetch origin --tags 2>/dev/null || git fetch --tags origin 2>/dev/null || true
    printf "\n"

    if ! git rev-parse "$tag^{}" >/dev/null 2>&1; then
        print_error "Unknown tag: ${tag}"
        printf "Fetch tags failed or tag does not exist on the remote. Try: ${BOLD}git fetch origin --tags${NC}\n"
        exit 1
    fi

    print_step "2/8" "Checking out ${tag}..."
    git checkout "$tag"
    printf "\n"

    print_step "3/8" "Release checkout (no git pull on a tag)..."
    print_success "At ${tag}"
    printf "\n"

    cmd_update_finish
}

cmd_update_branch() {
    local branch="$1"
    if ! validate_git_branch_name "$branch"; then
        print_error "Invalid branch name: ${branch:-empty}"
        printf "Use only letters, digits, and ${BOLD}.${NC}, ${BOLD}_${NC}, ${BOLD}/${NC}, ${BOLD}-${NC} (no ${BOLD}..${NC}).\n"
        exit 1
    fi

    print_header
    print_info "Target branch: ${BOLD}${branch}${NC} (origin/${branch})"
    printf "\n"

    require_clean_worktree

    print_step "1/8" "Fetching from origin..."
    git fetch origin "$branch"
    printf "\n"

    print_step "2/8" "Checking out ${branch}..."
    git checkout "$branch"
    printf "\n"

    print_step "3/8" "Pulling (fast-forward only)..."
    if ! git pull --ff-only origin "$branch"; then
        print_error "Fast-forward pull failed: local history diverges from origin/${branch}."
        printf "Resolve manually (merge/rebase) in ${INSTALL_DIR}, or align this clone with the remote before running update again.\n"
        exit 1
    fi
    printf "\n"

    cmd_update_finish
}

# ============================================================================
# Commands
# ============================================================================

cmd_help() {
    printf "\n"
    printf "${BOLD}📚 BookStorage v${APP_VERSION} - Personal reading tracker${NC}\n"
    printf "\n"
    printf "${BOLD}USAGE${NC}\n"
    printf "    bsctl ${BLUE}<command>${NC}\n"
    printf "\n"
    printf "${BOLD}DEVELOPMENT${NC}\n"
    printf "    ${GREEN}build${NC}        Compile the application\n"
    printf "    ${GREEN}build-prod${NC}   Compile for production (optimized)\n"
    printf "    ${GREEN}run${NC}          Start the development server\n"
    printf "    ${GREEN}clean${NC}        Remove compiled files\n"
    printf "\n"
    printf "${BOLD}PRODUCTION${NC} (requires root)\n"
    printf "    ${GREEN}install${NC}      Install the systemd service\n"
    printf "    ${GREEN}uninstall${NC}    Uninstall the service\n"
    printf "    ${GREEN}update${NC}         Interactive release (vX.0.0) or ${GREEN}BSCTL_UPDATE_TAG${NC}\n"
    printf "    ${GREEN}update main${NC}    Update from origin/main (fast-forward)\n"
    printf "    ${GREEN}update <branch>${NC}  Update from origin/<branch> (advanced)\n"
    printf "    ${GREEN}fix-perms${NC}    Fix file permissions\n"
    printf "\n"
    printf "${BOLD}SERVICE${NC}\n"
    printf "    ${GREEN}start${NC}        Start the service\n"
    printf "    ${GREEN}stop${NC}         Stop the service\n"
    printf "    ${GREEN}restart${NC}      Restart the service\n"
    printf "    ${GREEN}status${NC}       Show service status\n"
    printf "    ${GREEN}logs${NC}         Show logs in real-time\n"
    printf "\n"
    printf "${BOLD}EXAMPLES${NC}\n"
    printf "    ${BLUE}bsctl run${NC}              Local development\n"
    printf "    ${BLUE}sudo bsctl install${NC}     Install in production\n"
    printf "    ${BLUE}sudo bsctl update${NC}              Choose a Git release tag (menu)\n"
    printf "    ${BLUE}BSCTL_UPDATE_TAG=v3.1.1 sudo -E bsctl update${NC}  Non-interactive tag\n"
    printf "    ${BLUE}sudo bsctl update main${NC}         Sync to latest origin/main\n"
    printf "    ${BLUE}sudo bsctl update my-test-branch${NC}  Update from a branch\n"
    printf "    ${BLUE}bsctl logs${NC}             View logs\n"
    printf "\n"
    printf "${BOLD}CONFIGURATION${NC}\n"
    printf "    Environment variables in ${BLUE}.env${NC}:\n"
    printf "    - BOOKSTORAGE_HOST         (default: 127.0.0.1)\n"
    printf "    - BOOKSTORAGE_PORT         (default: 5000)\n"
    printf "    - BOOKSTORAGE_DATABASE     (default: database.db)\n"
    printf "    - BOOKSTORAGE_SECRET_KEY   (default: dev-secret-change-me)\n"
    printf "    - ${GREEN}BSCTL_UPDATE_TAG${NC}         (optional) e.g. v3.1.1 — skip menu on ${GREEN}bsctl update${NC}\n"
    printf "\n"
    printf "${BOLD}TAB COMPLETION (bash)${NC}\n"
    printf "    ${BLUE}source scripts/bsctl.completion.bash${NC}   (from the repo root)\n"
    printf "    or after install: ${BLUE}source /etc/bash_completion.d/bsctl${NC}\n"
    printf "\n"
}

cmd_version() {
    printf "BookStorage v${APP_VERSION}\n"
}

cmd_build() {
    print_info "Compiling..."
    go build -o ${APP_NAME} ./cmd/bookstorage
    print_success "Build complete: ./${APP_NAME}"
}

cmd_build_prod() {
    print_info "Compiling for production..."
    CGO_ENABLED=1 go build -ldflags="-s -w -X main.Version=${APP_VERSION}" -o ${APP_NAME} ./cmd/bookstorage
    print_success "Optimized binary created: ./${APP_NAME}"
}

cmd_run() {
    print_info "Starting development server..."
    go run ./cmd/bookstorage
}

cmd_clean() {
    print_info "Cleaning up..."
    rm -f ${APP_NAME}
    print_success "Cleanup complete"
}

cmd_install() {
    print_info "Installing ${APP_NAME} service..."
    cmd_build_prod
    cp ${APP_NAME} ${BIN_DIR}/
    cp scripts/bsctl ${BIN_DIR}/
    chmod +x ${BIN_DIR}/bsctl
    cp deploy/bookstorage.service /etc/systemd/system/
    if [[ -d /etc/bash_completion.d ]]; then
        cp scripts/bsctl.completion.bash /etc/bash_completion.d/bsctl
        chmod 644 /etc/bash_completion.d/bsctl
        print_success "Bash completion installed: /etc/bash_completion.d/bsctl (open a new shell or: source it)"
    fi
    systemctl daemon-reload
    systemctl enable ${APP_NAME}
    printf "\n"
    print_success "Service installed successfully"
    printf "\n"
    printf "Available commands:\n"
    printf "  ${BOLD}bsctl start${NC}   - Start\n"
    printf "  ${BOLD}bsctl stop${NC}    - Stop\n"
    printf "  ${BOLD}bsctl status${NC}  - Status\n"
}

cmd_uninstall() {
    print_info "Uninstalling ${APP_NAME} service..."
    systemctl stop ${APP_NAME} 2>/dev/null || true
    systemctl disable ${APP_NAME} 2>/dev/null || true
    rm -f /etc/systemd/system/bookstorage.service
    rm -f ${BIN_DIR}/${APP_NAME}
    rm -f ${BIN_DIR}/bsctl
    rm -f /etc/bash_completion.d/bsctl 2>/dev/null || true
    systemctl daemon-reload
    print_success "Service uninstalled"
}

cmd_update() {
    local arg="${1:-}"
    if [[ -n "$arg" ]]; then
        cmd_update_branch "$arg"
        return
    fi

    require_clean_worktree

    local tag=""
    if [[ -n "${BSCTL_UPDATE_TAG:-}" ]]; then
        if ! tag=$(normalize_tag "${BSCTL_UPDATE_TAG}"); then
            print_error "Invalid BSCTL_UPDATE_TAG"
            exit 1
        fi
    else
        tag=$(prompt_release_choice)
    fi

    cmd_update_at_tag "$tag"
}

cmd_fix_perms() {
    print_info "Fixing permissions..."
    chown ${APP_USER}:${APP_GROUP} . 2>/dev/null || true
    chmod 755 . 2>/dev/null || true
    chown ${APP_USER}:${APP_GROUP} database.db 2>/dev/null || true
    chmod 664 database.db 2>/dev/null || true
    chown -R ${APP_USER}:${APP_GROUP} static/avatars/ 2>/dev/null || true
    chown -R ${APP_USER}:${APP_GROUP} static/images/ 2>/dev/null || true
    chown -R ${APP_USER}:${APP_GROUP} templates/ 2>/dev/null || true
    print_success "Permissions fixed"
}

cmd_start() {
    print_info "Starting service..."
    systemctl start ${APP_NAME}
    print_success "Service started"
    cmd_status
}

cmd_stop() {
    print_info "Stopping service..."
    systemctl stop ${APP_NAME}
    print_success "Service stopped"
}

cmd_restart() {
    print_info "Restarting service..."
    systemctl restart ${APP_NAME}
    print_success "Service restarted"
    cmd_status
}

cmd_status() {
    systemctl status ${APP_NAME} --no-pager -l 2>/dev/null || printf "${YELLOW}Service not installed${NC}\n"
}

cmd_logs() {
    print_info "Real-time logs (Ctrl+C to quit)..."
    journalctl -u ${APP_NAME} -f
}

# ============================================================================
# Main
# ============================================================================

case "${1:-help}" in
    help|-h|--help)
        cmd_help
        ;;
    version|-v|--version)
        cmd_version
        ;;
    build)
        cmd_build
        ;;
    build-prod)
        cmd_build_prod
        ;;
    run)
        cmd_run
        ;;
    clean)
        cmd_clean
        ;;
    install)
        cmd_install
        ;;
    uninstall)
        cmd_uninstall
        ;;
    update)
        cmd_update "${2:-}"
        ;;
    fix-perms)
        cmd_fix_perms
        ;;
    start)
        cmd_start
        ;;
    stop)
        cmd_stop
        ;;
    restart)
        cmd_restart
        ;;
    status)
        cmd_status
        ;;
    logs)
        cmd_logs
        ;;
    *)
        printf "${YELLOW}Unknown command: ${1}${NC}\n\n"
        cmd_help
        exit 1
        ;;
esac
