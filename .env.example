# BookStorage — copy to ".env" and adjust (never commit .env)
#   cp .env.example .env
# On systemd, you can use: EnvironmentFile=/opt/bookstorage/.env

# In production:
#   - BOOKSTORAGE_SECRET_KEY must be set and at least 32 characters (not the dev default).
#     Sessions use DB-backed tokens today; this key is required as a production gate and for future crypto use.
#   - BOOKSTORAGE_SUPERADMIN_PASSWORD must be strong (>= 12 chars, upper, digit, symbol; not the defaults below).
BOOKSTORAGE_ENV=development

# Server
BOOKSTORAGE_HOST=127.0.0.1
BOOKSTORAGE_PORT=5000

# Data directory (relative to app root, or absolute). Database and paths resolve under this unless overridden.
# BOOKSTORAGE_DATA_DIR=.

# SQLite database file (relative to data dir, or absolute). Ignored when BOOKSTORAGE_POSTGRES_URL is set.
BOOKSTORAGE_DATABASE=database.db

# Optional: use PostgreSQL instead of SQLite (libpq URL). When set, BOOKSTORAGE_DATABASE is not used for persistence.
# Typical self-host: Postgres on another VM on the same private LAN/VPN (not public DNS). Use the server's private IP
# or a name your app VM resolves (e.g. /etc/hosts). Example:
#   postgresql://bookstorage:secret@192.168.1.117:5432/bookstorage?sslmode=disable
# sslmode: lib/pq accepts disable, require, verify-ca, verify-full (not "prefer").
# In production with a remote host, use sslmode=require (or verify-full) — disable is allowed for loopback, private LAN IPs (192.168.x.x, 10.x.x.x, …), and single-label hostnames (e.g. postgres via /etc/hosts).
# BOOKSTORAGE_POSTGRES_URL=

# Production gate (sessions use DB tokens; reserved for future signed cookies / crypto).
# Required length >= 32 when BOOKSTORAGE_ENV=production (non-default value).
BOOKSTORAGE_SECRET_KEY=dev-secret-change-me

# Super admin (created on first run if no superadmin exists).
# In production: must be strong and not equal to documented defaults below.
BOOKSTORAGE_SUPERADMIN_USERNAME=superadmin
BOOKSTORAGE_SUPERADMIN_PASSWORD=ChangeThisPassword!

# Account approval / validation
# - true (default): new accounts must be approved by an admin before login
# - false: users can login immediately after registration
# BOOKSTORAGE_REQUIRE_ACCOUNT_VALIDATION=true

# Optional: upload paths (defaults relative to project root)
# BOOKSTORAGE_UPLOAD_DIR=static/images
# BOOKSTORAGE_AVATAR_DIR=static/avatars
# BOOKSTORAGE_UPLOAD_URL_PATH=images
# BOOKSTORAGE_AVATAR_URL_PATH=avatars

# Optional: send Strict-Transport-Security only when the app is served over HTTPS
# BOOKSTORAGE_ENABLE_HSTS=false

# Optional: Sign in with Google (OAuth 2.0). Set all three; redirect URI in Google Cloud Console must be
#   {BOOKSTORAGE_PUBLIC_ORIGIN}/auth/google/callback
# In production, BOOKSTORAGE_PUBLIC_ORIGIN must be https://...
# BOOKSTORAGE_PUBLIC_ORIGIN=https://your-domain.example
# BOOKSTORAGE_GOOGLE_CLIENT_ID=
# BOOKSTORAGE_GOOGLE_CLIENT_SECRET=

# Timezone for displaying times in the web UI (IANA name).
# Auto-detected from the system/VM timezone if omitted. Override only if needed.
# BOOKSTORAGE_TIMEZONE=Europe/Paris

# Optional: protect GET /metrics for Prometheus (Authorization: Bearer only). If unset, only loopback may scrape /metrics.
# BOOKSTORAGE_METRICS_TOKEN=

# Backups (used by bsctl backup and admin /admin/backups)
# BOOKSTORAGE_BACKUP_DIR=/var/lib/bookstorage/backups
# BOOKSTORAGE_BACKUP_RETENTION_DAYS=14
# BOOKSTORAGE_ENV_FILE=/opt/bookstorage/.env

# Optional: API access for bsctl works commands and integrations
# BOOKSTORAGE_API_URL=http://127.0.0.1:5000
# BOOKSTORAGE_TOKEN=bs_...   (Bearer token with works:read / works:write scopes)

# WebAuthn / Passkeys — uses BOOKSTORAGE_PUBLIC_ORIGIN hostname as RP ID when set; otherwise http://BOOKSTORAGE_HOST:PORT in dev
# BOOKSTORAGE_PUBLIC_ORIGIN=https://your-domain.example

# Optional: transactional email via Mailjet (password reset). Requires all four variables below.
# Create an account at https://www.mailjet.com/fr/ and verify your sending domain (SPF/DKIM/DMARC).
# Users must have a valid email saved in their profile to use password reset.
# BOOKSTORAGE_MAILJET_API_KEY_PUBLIC=
# BOOKSTORAGE_MAILJET_API_KEY_PRIVATE=
# BOOKSTORAGE_MAIL_FROM=BookStorage <noreply@your-domain.example>

# Set to true when behind a trusted reverse proxy that sets X-Forwarded-For (rate limiting client IP).
# BOOKSTORAGE_TRUST_PROXY=false

# Optional: machine-translate AniList descriptions (LibreTranslate-compatible API, POST /translate)
# Example public instance (rate limits may apply): https://libretranslate.com
# BOOKSTORAGE_TRANSLATE_URL=
# BOOKSTORAGE_TRANSLATE_API_KEY=
